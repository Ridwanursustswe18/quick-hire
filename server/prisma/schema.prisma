generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum UserRole {
  ADMIN
  USER
  EMPLOYER
}
enum EnumEmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  INTERN
  VOLUNTEER
  OTHER
}
enum EnumExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
}
model User{
    id        Int           @id @default(autoincrement())
    name      String
    email     String        @unique
    password  String
    role      UserRole
    createdAt DateTime      @default(now())    
    applications Application[]
}
model Job {
  id          Int           @id @default(autoincrement())
  title       String
  company     String
  location    String
  category    String
  description String
  createdAt   DateTime      @default(now())
  salary      Float?
  employmentType EnumEmploymentType?   
  experienceLevel EnumExperienceLevel?
  remote      Boolean?
  skills      String[]
  applications Application[]
}

model Application {
  id          Int      @id @default(autoincrement())
  jobId       Int
  userId      Int?
  name        String
  email       String
  resumeLink  String
  coverNote   String?
  status      ApplicationStatus @default(PENDING)
  createdAt   DateTime @default(now())
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
}